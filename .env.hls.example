# HLS Conversion Configuration
# Add these to your existing .env file

# HLS segment duration in seconds (default: 10)
HLS_SEGMENT_DURATION=10

# Temporary directory for HLS conversion (will be auto-created)
HLS_TEMP_DIR=./temp/hls

# Auto-delete original MP4 after successful HLS conversion (true/false)
AUTO_DELETE_ORIGINAL_MP4=false
